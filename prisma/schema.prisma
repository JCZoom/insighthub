generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String
  avatarUrl   String?
  role        String           @default("VIEWER")
  department  String?
  hasOnboarded Boolean         @default(false)
  createdAt   DateTime         @default(now())
  lastLoginAt DateTime?
  dashboards  Dashboard[]      @relation("owner")
  sharedWith  DashboardShare[]
  chatSessions ChatSession[]
  auditLogs        AuditLog[]
  publishedWidgets WidgetTemplate[] @relation("publishedWidgets")
}

// Role values: VIEWER, CREATOR, POWER_USER, ADMIN (stored as String for SQLite)

model Dashboard {
  id             String             @id @default(cuid())
  title          String
  description    String?
  thumbnailUrl   String?
  ownerId        String
  owner          User               @relation("owner", fields: [ownerId], references: [id])
  folderId       String?
  folder         Folder?            @relation(fields: [folderId], references: [id])
  currentVersion Int                @default(1)
  versions       DashboardVersion[]
  shares         DashboardShare[]
  tags           String             @default("")
  isTemplate     Boolean            @default(false)
  isPublic       Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  archivedAt     DateTime?

  @@index([ownerId])
  @@index([folderId])
}

model DashboardVersion {
  id          String    @id @default(cuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  version     Int
  schema      String
  changeNote  String?
  createdAt   DateTime  @default(now())
  createdBy   String

  @@index([dashboardId, version])
}

model DashboardShare {
  id          String          @id @default(cuid())
  dashboardId String
  dashboard   Dashboard       @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  permission  String          @default("VIEW")
  createdAt   DateTime        @default(now())

  @@unique([dashboardId, userId])
}

// SharePermission values: VIEW, COMMENT, EDIT

model Folder {
  id         String           @id @default(cuid())
  name       String
  parentId   String?
  parent     Folder?          @relation("children", fields: [parentId], references: [id])
  children   Folder[]         @relation("children")
  dashboards Dashboard[]
  ownerId    String
  visibility String           @default("PRIVATE")
  createdAt  DateTime         @default(now())
}

// FolderVisibility values: PRIVATE, TEAM, PUBLIC

model ChatSession {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  dashboardId String?
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String
  content      String
  schemaChange String?
  createdAt    DateTime    @default(now())
}

// MessageRole values: USER, ASSISTANT, SYSTEM

model GlossaryTerm {
  id             String   @id @default(cuid())
  term           String   @unique
  definition     String
  formula        String?
  category       String
  examples       String?
  relatedTerms   String             @default("")
  dataSource     String?
  lastReviewedAt DateTime?
  approvedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
}

model WidgetTemplate {
  id                   String    @id @default(cuid())
  title                String
  description          String?
  type                 String
  tags                 String             @default("")
  config               String
  sourceDashboardId    String?
  sourceDashboardTitle String?
  publishedById        String?
  publishedBy          User?     @relation("publishedWidgets", fields: [publishedById], references: [id])
  usageCount           Int       @default(0)
  isPublic             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([type])
  @@index([publishedById])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  action       String
  resourceType String
  resourceId   String
  metadata     String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([resourceType, resourceId])
}

// Sample Data Tables for Demo (Phase 1)
model SampleCustomer {
  id              Int                    @id @default(autoincrement())
  name            String                 @db.VarChar(100)
  email           String                 @db.VarChar(100)
  company         String                 @db.VarChar(100)
  plan            String                 @db.VarChar(20) // 'starter', 'professional', 'enterprise'
  region          String                 @db.VarChar(30) // 'Northeast', 'Southeast', 'Midwest', 'West', 'International'
  signupDate      DateTime               @map("signup_date") @db.Date
  cancelledDate   DateTime?              @map("cancelled_date") @db.Date
  monthlyRevenue  Decimal                @map("monthly_revenue") @db.Decimal(10, 2)
  accountManager  String?                @map("account_manager") @db.VarChar(80)
  subscriptions   SampleSubscription[]
  tickets         SampleTicket[]
  revenue         SampleRevenue[]
  usage           SampleUsage[]

  @@map("sample_customers")
}

model SampleSubscription {
  id            Int             @id @default(autoincrement())
  customerId    Int             @map("customer_id")
  customer      SampleCustomer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan          String          @db.VarChar(20)
  status        String          @db.VarChar(15) // 'active', 'cancelled', 'paused', 'trial'
  startDate     DateTime        @map("start_date") @db.Date
  endDate       DateTime?       @map("end_date") @db.Date
  monthlyAmount Decimal         @map("monthly_amount") @db.Decimal(10, 2)
  addOns        Json?           @map("add_ons") // [{"name": "Premium Support", "amount": 49.99}]

  @@map("sample_subscriptions")
}

model SampleTicket {
  id                      Int             @id @default(autoincrement())
  customerId              Int             @map("customer_id")
  customer                SampleCustomer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subject                 String          @db.VarChar(200)
  category                String          @db.VarChar(50) // 'billing', 'technical', 'onboarding', 'feature_request', 'cancellation'
  priority                String          @db.VarChar(10) // 'low', 'medium', 'high', 'urgent'
  status                  String          @db.VarChar(15) // 'open', 'pending', 'resolved', 'closed'
  channel                 String          @db.VarChar(20) // 'email', 'chat', 'phone', 'portal'
  createdAt               DateTime        @map("created_at")
  resolvedAt              DateTime?       @map("resolved_at")
  firstResponseMinutes    Int?            @map("first_response_minutes")
  satisfactionScore       Int?            @map("satisfaction_score") // 1-5 CSAT
  agent                   String?         @db.VarChar(80)
  team                    String?         @db.VarChar(50) // 'Recipient Support', 'Form 1583', 'Sales', 'Mail Centers', 'Partner AI'

  @@map("sample_tickets")
}

model SampleRevenue {
  id         Int             @id @default(autoincrement())
  customerId Int             @map("customer_id")
  customer   SampleCustomer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  eventType  String          @map("event_type") @db.VarChar(20) // 'new', 'expansion', 'contraction', 'churn', 'reactivation'
  amount     Decimal         @db.Decimal(10, 2)
  eventDate  DateTime        @map("event_date") @db.Date
  planFrom   String?         @map("plan_from") @db.VarChar(20)
  planTo     String?         @map("plan_to") @db.VarChar(20)

  @@map("sample_revenue")
}

model SampleUsage {
  id         Int             @id @default(autoincrement())
  customerId Int             @map("customer_id")
  customer   SampleCustomer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  feature    String          @db.VarChar(50) // 'mail_scan', 'package_forward', 'check_deposit', 'address_use'
  usageCount Int             @map("usage_count")
  usageDate  DateTime        @map("usage_date") @db.Date

  @@map("sample_usage")
}

model SampleDeal {
  id          Int       @id @default(autoincrement())
  company     String    @db.VarChar(100)
  contact     String    @db.VarChar(80)
  stage       String    @db.VarChar(20) // 'prospect', 'qualified', 'proposal', 'negotiation', 'closed_won', 'closed_lost'
  amount      Decimal   @db.Decimal(12, 2)
  probability Int       // 0-100
  source      String    @db.VarChar(30) // 'inbound', 'outbound', 'referral', 'partner'
  region      String    @db.VarChar(30)
  createdAt   DateTime  @map("created_at") @db.Date
  closedAt    DateTime? @map("closed_at") @db.Date
  owner       String    @db.VarChar(80)

  @@map("sample_deals")
}
