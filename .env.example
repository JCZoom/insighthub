# Database (SQLite — zero infrastructure, just works)
DATABASE_URL="file:./dev.db"

# Auth (Google OAuth — Phase 2)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
ALLOWED_DOMAIN="uszoom.com"

# AI
ANTHROPIC_API_KEY=""

# Voice (OpenAI Whisper for speech-to-text)
OPENAI_API_KEY=""

# ── Dev-mode flags (TWO flags, by design) ──────────────────────────────────
#
# DEV_MODE (server-only, runtime-evaluated) is the SECURITY flag.
#   Controls auth bypass in middleware, NextAuth callbacks, session helpers.
#   Read at request time, so flipping this file + restarting the service is
#   sufficient to toggle. MUST be "false" (or unset) in production.
#
# NEXT_PUBLIC_DEV_MODE (client, build-baked) is the UI HINT flag.
#   Controls cosmetic dev affordances (dev login button on /login, etc).
#   Inlined into the JS bundle at `next build` time — runtime changes have
#   NO effect. NOT a security flag.
#
# Keep these two values in sync. validateEnv() warns at startup if they disagree.
# Background: docs/INCIDENT_RESPONSE_RUNBOOK.md entry, 2026-05-19 lockdown.
DEV_MODE="true"
NEXT_PUBLIC_DEV_MODE="true"

# Escape hatch for the assertEnv() hard-throw on NODE_ENV=production +
# DEV_MODE=true (added 2026-05-20 per INC-20260519-001 retro). Set ONLY in
# CI's e2e step, where a production-shaped build is intentionally run with
# auth bypassed for Playwright. NEVER set this in /opt/insighthub/.env.local
# or any real production environment — if you find yourself wanting to,
# fix the underlying misconfiguration instead.
# ALLOW_DEV_MODE_IN_PRODUCTION="1"

# Comma-separated list of Google Workspace domains whose 2SV enforcement we
# trust as the MFA control when Google omits the `amr` claim from the
# id_token (which it routinely does in password-then-key flows). Empty or
# unset = strict mode (require explicit amr assertion — currently lock-out
# behavior for password+YubiKey flows). See src/lib/auth/mfa.ts for the
# full trust assumption write-up.
#
# Only list domains you administer and whose Workspace policy you have
# verified enforces 2SV for all users.
TRUSTED_MFA_DOMAINS="uszoom.com"

# Asana Integration
ASANA_PERSONAL_ACCESS_TOKEN=""
ASANA_WORKSPACE_GID=""
ASANA_PROJECT_GID=""

# ── Backup encryption & cross-region isolation (gap G-13) ────────────
# Generate key with: openssl rand -base64 32
# When BACKUP_S3_BUCKET is set, BACKUP_ENCRYPTION_KEY is MANDATORY.
# Setup: ./scripts/setup-backup-isolation.sh
# Docs:  docs/BACKUP_ISOLATION_SETUP.md
BACKUP_ENCRYPTION_KEY=""
BACKUP_REGION="us-west-2"
BACKUP_S3_BUCKET=""
BACKUP_KMS_KEY_ID=""
# Writer credentials live on the production EC2 host (PutObject-only policy):
BACKUP_WRITER_AWS_ACCESS_KEY_ID=""
BACKUP_WRITER_AWS_SECRET_ACCESS_KEY=""
# Reader credentials should NOT be on EC2 — keep in your password manager
# and load only when running scripts/restore-from-s3.sh:
# BACKUP_READER_AWS_ACCESS_KEY_ID=""
# BACKUP_READER_AWS_SECRET_ACCESS_KEY=""

# Snowflake (Phase 3)
SNOWFLAKE_ACCOUNT=""
SNOWFLAKE_USERNAME=""
SNOWFLAKE_PASSWORD=""
SNOWFLAKE_WAREHOUSE=""
SNOWFLAKE_DATABASE=""
SNOWFLAKE_SCHEMA=""
SNOWFLAKE_ROLE=""

# Redis (Query caching layer for Snowflake)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# AI Spend Tracker (Google Sheets — see docs/AI_SPEND_TRACKER_SETUP.md)
SPEND_TRACKER_SHEET_ID=""
SPEND_TRACKER_SA_KEY="~/.config/ai-spend-tracker-sa.json"

# Data Integrity Verification Pipeline
VERIFY_INTEGRITY_ENABLED="true"
VERIFY_INTEGRITY_AI_ENABLED="true"
VERIFY_INTEGRITY_CONFIDENCE_THRESHOLD="0.70"
VERIFY_INTEGRITY_TIMEOUT_MS="5000"

# Demo (sample) data sources quarantine flag.
# When false (default), the 27 canonical sample_* / kpi_summary /
# *_by_month / cs_* sources served by src/lib/data/sample-data.ts are
# HIDDEN from discovery surfaces (LLM source catalog, source pickers,
# schema explorer). Saved dashboards continue to render — only
# discovery is quarantined. Flip to true on local/dev to build new
# dashboards against the seed-data generators.
# Architectural notes: docs/REAL_DATA_MIGRATION_PLAN_2026-05-19.md §3
FEATURE_DEMO_SOURCES="false"

# Client-side mirror of FEATURE_DEMO_SOURCES (UI hint flag). Build-baked
# at `next build` time. Gates the hardcoded demo-template lists in the
# Templates page, the Gallery initial state, and the editor's
# TEMPLATE_SCHEMAS hydration. Keep this value in sync with
# FEATURE_DEMO_SOURCES — assertEnv() warns at boot if they desync.
# NOT a security flag; data-honesty is enforced by FEATURE_DEMO_SOURCES.
NEXT_PUBLIC_FEATURE_DEMO_SOURCES="false"
