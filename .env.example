# Database (SQLite — zero infrastructure, just works)
DATABASE_URL="file:./dev.db"

# Auth (Google OAuth — Phase 2)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
ALLOWED_DOMAIN="uszoom.com"

# AI
ANTHROPIC_API_KEY=""

# Voice (OpenAI Whisper for speech-to-text)
OPENAI_API_KEY=""

# Dev mode — bypasses auth, auto-logs in as admin
NEXT_PUBLIC_DEV_MODE="true"

# Asana Integration
ASANA_PERSONAL_ACCESS_TOKEN=""
ASANA_WORKSPACE_GID=""
ASANA_PROJECT_GID=""

# Backup encryption (AES-256-CBC — generate with: openssl rand -base64 32)
BACKUP_ENCRYPTION_KEY=""

# Snowflake (Phase 3)
SNOWFLAKE_ACCOUNT=""
SNOWFLAKE_USERNAME=""
SNOWFLAKE_PASSWORD=""
SNOWFLAKE_WAREHOUSE=""
SNOWFLAKE_DATABASE=""
SNOWFLAKE_SCHEMA=""
SNOWFLAKE_ROLE=""

# Redis (Query caching layer for Snowflake)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# Data Integrity Verification Pipeline
VERIFY_INTEGRITY_ENABLED="true"
VERIFY_INTEGRITY_AI_ENABLED="true"
VERIFY_INTEGRITY_CONFIDENCE_THRESHOLD="0.70"
VERIFY_INTEGRITY_TIMEOUT_MS="5000"
