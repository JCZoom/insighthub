# Database (SQLite — zero infrastructure, just works)
DATABASE_URL="file:./dev.db"

# Auth (Google OAuth — Phase 2)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
ALLOWED_DOMAIN="uszoom.com"

# AI
ANTHROPIC_API_KEY=""

# Voice (OpenAI Whisper for speech-to-text)
OPENAI_API_KEY=""

# Dev mode — bypasses auth, auto-logs in as admin
NEXT_PUBLIC_DEV_MODE="true"

# Asana Integration
ASANA_PERSONAL_ACCESS_TOKEN=""
ASANA_WORKSPACE_GID=""
ASANA_PROJECT_GID=""

# ── Backup encryption & cross-region isolation (gap G-13) ────────────
# Generate key with: openssl rand -base64 32
# When BACKUP_S3_BUCKET is set, BACKUP_ENCRYPTION_KEY is MANDATORY.
# Setup: ./scripts/setup-backup-isolation.sh
# Docs:  docs/BACKUP_ISOLATION_SETUP.md
BACKUP_ENCRYPTION_KEY=""
BACKUP_REGION="us-west-2"
BACKUP_S3_BUCKET=""
BACKUP_KMS_KEY_ID=""
# Writer credentials live on the production EC2 host (PutObject-only policy):
BACKUP_WRITER_AWS_ACCESS_KEY_ID=""
BACKUP_WRITER_AWS_SECRET_ACCESS_KEY=""
# Reader credentials should NOT be on EC2 — keep in your password manager
# and load only when running scripts/restore-from-s3.sh:
# BACKUP_READER_AWS_ACCESS_KEY_ID=""
# BACKUP_READER_AWS_SECRET_ACCESS_KEY=""

# Snowflake (Phase 3)
SNOWFLAKE_ACCOUNT=""
SNOWFLAKE_USERNAME=""
SNOWFLAKE_PASSWORD=""
SNOWFLAKE_WAREHOUSE=""
SNOWFLAKE_DATABASE=""
SNOWFLAKE_SCHEMA=""
SNOWFLAKE_ROLE=""

# Redis (Query caching layer for Snowflake)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# AI Spend Tracker (Google Sheets — see docs/AI_SPEND_TRACKER_SETUP.md)
SPEND_TRACKER_SHEET_ID=""
SPEND_TRACKER_SA_KEY="~/.config/ai-spend-tracker-sa.json"

# Data Integrity Verification Pipeline
VERIFY_INTEGRITY_ENABLED="true"
VERIFY_INTEGRITY_AI_ENABLED="true"
VERIFY_INTEGRITY_CONFIDENCE_THRESHOLD="0.70"
VERIFY_INTEGRITY_TIMEOUT_MS="5000"
